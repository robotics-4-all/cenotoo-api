# Application
APP_NAME=services
ENVIRONMENT=development

# Admin credentials (required for admin access)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# JWT Settings
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=230

# Kafka
KAFKA_BROKERS=localhost:59498

# Kafka Auth (leave empty to disable SASL authentication)
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT

# Cassandra
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=metadata

# Cassandra Auth (leave empty to disable authentication)
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# API Key Secret (used for key generation)
API_KEY_SECRET=CHANGE_ME_IN_PRODUCTION

# Organization
ORGANIZATION_ID=YOUR_ORGANIZATION_UUID_HERE

# Rate Limiting (slowapi format: "N/period" e.g. 120/minute, 10/second)
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute

# OpenTelemetry (leave OTLP_ENDPOINT empty to disable tracing)
OTLP_ENDPOINT=
OTLP_SERVICE_NAME=cenotoo-api
